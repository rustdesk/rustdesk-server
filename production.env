# 生产环境配置文件
# 请根据实际生产环境需求修改以下配置

# 数据库配置
DATABASE_URL=sqlite:///data/hbbs.db

# 安全配置（必须修改）
KEY=your-super-secure-production-key-change-this
JWT_SECRET=your-super-secure-jwt-secret-change-this

# 端口配置
PORT=21115
API_PORT=8080

# 日志配置
RUST_LOG=warn

# 网络配置
LAN_MASK=10.0.0.0/8

# 性能配置
MAX_CONNECTIONS=5000
CONNECTION_TIMEOUT=60

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 安全配置
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=200

# 邮件配置
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=RustDesk Server <noreply@yourdomain.com>

# 第三方服务配置
SENTRY_DSN=https://your-sentry-dsn
PROMETHEUS_GATEWAY=https://your-prometheus-gateway

# Redis 配置（分布式部署）
REDIS_URL=redis://redis-server:6379

# SSL/TLS 配置
SSL_CERT_PATH=/etc/ssl/cert.pem
SSL_KEY_PATH=/etc/ssl/key.pem

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backup/hbbs
