# 环境变量配置示例文件
# 复制为 .env 文件并根据实际环境修改配置

# 数据库配置
DATABASE_URL=sqlite://./db_v2.sqlite3

# 服务器密钥（生产环境请修改为强密钥）
KEY=

# 端口配置
PORT=21115
API_PORT=8080

# JWT 配置
JWT_SECRET=your-jwt-secret-change-in-production

# 日志配置
RUST_LOG=info

# 网络配置
LAN_MASK=192.168.0.0/16

# 性能配置
MAX_CONNECTIONS=1000
CONNECTION_TIMEOUT=30

# 带宽配置（hbbr）
TOTAL_BANDWIDTH=0
SINGLE_BANDWIDTH=0
LIMIT_SPEED=0

# 降级配置（hbbr）
DOWNGRADE_THRESHOLD=0.66
DOWNGRADE_START_CHECK=1800

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 安全配置
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=100

# Redis 配置（可选，用于分布式部署）
REDIS_URL=redis://localhost:6379

# 邮件配置（用于密码重置等功能）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# 第三方服务配置
SENTRY_DSN=
PROMETHEUS_GATEWAY=
