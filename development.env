# 开发环境配置文件
# 用于本地开发和测试

# 数据库配置
DATABASE_URL=sqlite://./db_v2.sqlite3

# 开发环境密钥（仅用于测试）
KEY=dev-key-12345

# 端口配置
PORT=21115
API_PORT=8080

# 日志配置
RUST_LOG=debug

# 网络配置
LAN_MASK=192.168.1.0/24

# 性能配置（开发环境较低）
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30

# 带宽配置（开发环境无限制）
TOTAL_BANDWIDTH=0
SINGLE_BANDWIDTH=0
LIMIT_SPEED=0

# 降级配置（开发环境）
DOWNGRADE_THRESHOLD=0.66
DOWNGRADE_START_CHECK=1800000

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 安全配置（开发环境宽松）
ENABLE_RATE_LIMIT=false
RATE_LIMIT_PER_MINUTE=1000

# 邮件配置（开发环境使用测试服务）
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM=dev@rustdesk.local

# 第三方服务配置
SENTRY_DSN=
PROMETHEUS_GATEWAY=

# Redis 配置（本地开发）
REDIS_URL=redis://localhost:6379

# 开发特定配置
DEV_MODE=true
AUTO_MIGRATE=true
SEED_DATA=true

# 测试用户配置
TEST_ADMIN_EMAIL=admin@rustdesk.local
TEST_ADMIN_PASSWORD=admin123
TEST_USER_EMAIL=user@rustdesk.local
TEST_USER_PASSWORD=user123
